# Emby Playback Guardian configuration
# Copy to .env and fill in your values

# Media Server (required)
EMBY_URL=http://your-emby-server:8096
EMBY_API_KEY=your-api-key-here
SERVER_TYPE=emby

# qBittorrent (optional)
QBIT_URL=
QBIT_USERNAME=admin
QBIT_PASSWORD=

# SABnzbd (optional)
SABNZBD_URL=
SABNZBD_API_KEY=
SABNZBD_THROTTLE_PCT=50

# Disk I/O monitoring (optional)
DISK_DEVICES=
DISK_PROC_PATH=/host/proc/diskstats
DISK_SAMPLE_SECONDS=2

# Behavior
POLL_INTERVAL=30
STUCK_SCAN_TIMEOUT=7200
STUCK_STALL_MINUTES=15
IO_THRESHOLD=80
DRY_RUN=true
LOG_LEVEL=INFO
TZ=UTC

# Retry behavior (optional)
MAX_RETRIES=3
RETRY_BACKOFF=2
RETRY_BASE_DELAY=1

# Startup retry (optional)
STARTUP_RETRIES=10
STARTUP_RETRY_DELAY=30

# Health check / metrics (optional, set to 0 to disable)
HEALTH_PORT=8095

# Task names to pause during playback (comma-separated, case-insensitive substring match)
# PAUSABLE_TASKS=Scan media library,Refresh Guide,Download subtitles,Video preview thumbnail extraction,Scan Metadata Folder

# Notifications (optional)
DISCORD_WEBHOOK_URL=
WEBHOOK_URL=

# Custom throttle hooks (optional)
# Shell commands executed when throttle state changes. Number suffix controls order.
# THROTTLE_HOOK_ON_1=echo "throttled"
# THROTTLE_HOOK_OFF_1=echo "restored"
# THROTTLE_HOOK_TIMEOUT=30
